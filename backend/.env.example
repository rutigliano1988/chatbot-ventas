# ── Servidor ──────────────────────────────────────────────
PORT=3000

# ── Base de datos (Supabase PostgreSQL) ───────────────────
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ── WhatsApp Business API (Meta) ──────────────────────────
WHATSAPP_VERIFY_TOKEN=token_que_eliges_tu
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
# App Secret de tu app en Meta for Developers → Configuración básica → Secreto de la app
WHATSAPP_APP_SECRET=

# ── Google Calendar (OAuth2) ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
CALENDAR_TIMEZONE=America/Argentina/Buenos_Aires
CALENDAR_TZ_OFFSET=-03:00
RESERVA_DURACION_MINUTOS=90

# ── SendGrid (emails) ─────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notificaciones@tudominio.com

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
NEGOCIO_ID=1

# ── Seguridad del dashboard ───────────────────────────────
# Clave secreta para proteger la API (debe coincidir con REACT_APP_API_KEY del frontend)
API_KEY=cambia_esto_por_una_clave_larga_y_aleatoria
# URL del frontend en producción (Vercel)
FRONTEND_URL=https://tu-app.vercel.app
