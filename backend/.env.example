# ── Servidor ──────────────────────────────────────────────
PORT=3000

# ── Base de datos (Supabase PostgreSQL) ───────────────────
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ── WhatsApp Business API (Meta) ──────────────────────────
WHATSAPP_VERIFY_TOKEN=token_que_eliges_tu
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=

# ── Google Calendar (OAuth2) ──────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
CALENDAR_TIMEZONE=America/Argentina/Buenos_Aires
CALENDAR_TZ_OFFSET=-03:00
RESERVA_DURACION_MINUTOS=90

# ── SendGrid (emails) ─────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notificaciones@tudominio.com

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
NEGOCIO_ID=1
